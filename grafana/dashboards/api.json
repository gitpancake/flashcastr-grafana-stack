      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Request Rate by Operation",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(flashcastr_api_graphql_requests_total{job=\"flashcastr-api\"}[$__rate_interval])) by (operation_name)", "legendFormat": "{{operation_name}}", "refId": "A" }
