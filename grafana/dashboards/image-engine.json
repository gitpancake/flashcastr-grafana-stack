      "type": "stat",
      "targets": [{ "expr": "rate(image_engine_ipfs_uploads_total{job=\"image-engine\"}[$__rate_interval]) / (rate(image_engine_ipfs_uploads_total{job=\"image-engine\"}[$__rate_interval]) + rate(image_engine_ipfs_failures_total{job=\"image-engine\"}[$__rate_interval]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
