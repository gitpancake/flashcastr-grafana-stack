ARG VERSION=v3.2.1

FROM prom/prometheus:${VERSION}

USER root

# Copy the template config
COPY prom.yml /etc/prometheus/prom.yml.template

# Create entrypoint script that substitutes env vars at runtime
RUN echo '#!/bin/sh' > /entrypoint.sh && \
    echo 'set -e' >> /entrypoint.sh && \
    echo 'envsubst < /etc/prometheus/prom.yml.template > /etc/prometheus/prom.yml' >> /entrypoint.sh && \
    echo 'exec /bin/prometheus "$@"' >> /entrypoint.sh && \
    chmod +x /entrypoint.sh

# Install envsubst (from gettext package)
RUN apk add --no-cache gettext

ENTRYPOINT ["/entrypoint.sh"]
CMD ["--config.file=/etc/prometheus/prom.yml", "--storage.tsdb.path=/prometheus", "--web.enable-remote-write-receiver"]
